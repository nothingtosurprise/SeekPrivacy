<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"> <ImageView
        android:id="@+id/topFlow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/orange_wave"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.35" /> <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#F0FFFFFF" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            
            

            <TextView
                android:id="@+id/appNameAndCreator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seek the Privacy"
                android:textColor="#333333" android:textSize="28sp"
                android:letterSpacing="0.02"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/creatorInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Created by Seeker - Founder @ SeeknWander"
                android:textColor="#757575"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/hope"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hope you'll like it!"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="italic"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/contactUsBelow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="For any issues, please reach me at: mytuta05@tutamail.com"
                android:textColor="#2196F3"
                android:textSize="14sp"
                android:textStyle="bold"
                android:autoLink="email"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/encryptedFolderLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="24dp" app:cardElevation="10dp" app:cardBackgroundColor="#212121" app:strokeColor="#FF9800"
        app:strokeWidth="1dp" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/decryptedFolderLayout"
        app:layout_constraintTop_toBottomOf="@id/topFlow"
        app:layout_constraintHorizontal_weight="1"
        android:layout_marginTop="-30dp" android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp">

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/ic_lock"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:tint="#FF9800" /> <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Encrypted"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:textColor="@android:color/white"/> </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/decryptedFolderLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="24dp" app:cardElevation="10dp" app:cardBackgroundColor="#212121" app:strokeColor="#2196F3"
        app:strokeWidth="1dp" app:layout_constraintStart_toEndOf="@id/encryptedFolderLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/encryptedFolderLayout"
        app:layout_constraintHorizontal_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp">

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/ic_folder"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:tint="#2196F3" /> <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decrypted"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:textColor="@android:color/white"/> </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
    android:id="@+id/infoCard"
    android:layout_width="0dp"
    android:layout_height="0dp" 
    android:layout_marginTop="32dp"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="24dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#2C2C2C" 
    app:layout_constraintTop_toBottomOf="@id/encryptedFolderLayout"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            
            
            
            <com.google.android.material.button.MaterialButton
    android:id="@+id/btnDeveloperSetup"
    style="@style/Widget.MaterialComponents.Button.TextButton"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_gravity="end"
    android:text="Set Developer"
    android:textColor="#FF9800"
    app:rippleColor="#4DFF9800" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 How to Use"
                android:textColor="#FF9800"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Tap 'Encrypted' to see all encrypted files and to encrypt new files. Decrypt files by clicking on them and providing authentication. --- You can encrypt multiple files. Rename, delete, move between subfolders, or share without moving them out of the app."
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>
                
             <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Now Activist-Grade Security: Never lose access even if you forget the recovery code. Strong hardware-backed KeyStore. - 5-minute RAM wipe. - Anti-forensic shredder. - Stealth logic. - Per-operation authentication with 5-minute cooldown. - Options for Password/Pattern/Biometrics (change mode anytime)."
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Warning: Uninstalling or clearing app data will permanently delete all files."
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Upgraded to AES/GCM/NoPadding with Legacy Support"
                android:textColor="#BDBDBD"
                android:textSize="14sp"/>
          

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
